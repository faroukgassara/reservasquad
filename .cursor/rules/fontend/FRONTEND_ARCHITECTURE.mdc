## Form Handling with TanStack Form and Zod

### Integration Pattern

**Full Example**: `src/components/pages/LoginPage/LoginPage.tsx`

```typescript
'use client'

import { useForm } from '@tanstack/react-form'
import { z } from 'zod'

export default function LoginPage() {
    const [error, setError] = useState<string | null>(null)

    // 1. Define Zod Schema
    const FormSchema = z.object({
        email: z.string()
            .min(1, 'Email is required')
            .email('Invalid email format'),
        password: z.string()
            .min(6, 'Password must be at least 6 characters')
            .max(12, 'Password must not exceed 12 characters'),
    })

    type FormData = z.infer<typeof FormSchema>

    // 2. Configure TanStack Form with Zod validation
    const form = useForm({
        defaultValues: {
            email: '',
            password: ''
        },
        validators: {
            onChange: FormSchema.parse,  // Real-time validation
        },
        onSubmit: async ({ value }) => {
            // 3. Handle submission
            setError(null)
            
            try {
                const response = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(value),
                })

                const data = await response.json()
                
                if (!response.ok) {
                    throw new Error(data.message)
                }
                
                // Handle success
                router.push('/dashboard')
            } catch (err: any) {
                setError(err.message)
            }
        },
    })

    return (
        <form onSubmit={(e) => form.handleSubmit()}>
            {/* Email field */}
            <form.Field name="email">
                {({ state, handleChange, handleBlur }) => (
                    <div>
                        <Input
                            type="email"
                            value={state.value}
                            onChange={(e) => handleChange(e.target.value)}
                            onBlur={handleBlur}
                        />
                        {state.meta.errors?.[0] && (
                            <p className="text-red-500">{state.meta.errors[0]}</p>
                        )}
                    </div>
                )}
            </form.Field>

            {/* Password field */}
            <form.Field name="password">
                {({ state, handleChange }) => (
                    <div>
                        <Input
                            type="password"
                            value={state.value}
                            onChange={(e) => handleChange(e.target.value)}
                        />
                        {state.meta.errors?.[0] && (
                            <p className="text-red-500">{state.meta.errors[0]}</p>
                        )}
                    </div>
                )}
            </form.Field>

            {/* Submit button */}
            <form.Subscribe>
                {({ isSubmitting }) => (
                    <Button
                        type="submit"
                        disabled={isSubmitting}
                        text="Login"
                    />
                )}
            </form.Subscribe>
        </form>
    )
}
```

### Validation Levels

1. **Real-time validation** (`onChange`): Validates as user types
2. **On-blur validation** (`onBlur`): Validates when field loses focus
3. **On-submit validation** (`onSubmit`): Final validation before submission

