## API Integration with TanStack Query

### QueryClient Setup

**Location**: `src/components/providers/QueryProvider.tsx`

```typescript
export default function QueryProvider({ children }) {
    const [queryClient] = useState(
        () =>
            new QueryClient({
                defaultOptions: {
                    queries: {
                        staleTime: 60 * 1000, // 1 minute
                        retry: (failureCount, error: any) => {
                            if (error?.status >= 400 && error?.status < 500) {
                                return false;
                            }
                            return failureCount < 3;
                        },
                    },
                    mutations: {
                        retry: false,
                    },
                },
            })
    )

    return (
        <QueryClientProvider client={queryClient}>
            {children}
            <ReactQueryDevtools initialIsOpen={false} />
        </QueryClientProvider>
    )
}
```

### Using TanStack Query

```typescript
'use client'

import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query'
import { Api } from '@/common'
import { CommonFunction } from '@/common'

// Fetch data
function useUserData(userId: string) {
    return useQuery({
        queryKey: ['user', userId],
        queryFn: async () => {
            const headers = await CommonFunction.createHeaders({ withToken: true })
            const api = new Api()
            const response = await api.get(`/users/${userId}`, headers)
            return response.data
        },
        enabled: !!userId,
    })
}

// Mutate data
function useUpdateUser() {
    const queryClient = useQueryClient()
    
    return useMutation({
        mutationFn: async (userData) => {
            const headers = await CommonFunction.createHeaders({ withToken: true })
            const api = new Api()
            const response = await api.put('/users', userData, headers)
            return response.data
        },
        onSuccess: () => {
            queryClient.invalidateQueries({ queryKey: ['user'] })
        },
    })
}

// Usage in component
export default function UserProfile({ userId }) {
    const { data: user, isLoading, error } = useUserData(userId)
    const updateUser = useUpdateUser()
    
    if (isLoading) return <Spinner />
    if (error) return <Error message={error.message} />
    
    return (
        <div>
            <h1>{user.name}</h1>
            <button onClick={() => updateUser.mutate({ name: 'New Name' })}>
                Update
            </button>
        </div>
    )
}
```

### Standard API Class

**Location**: `src/common/StandardApi/api/index.ts`

```typescript
export class Api implements IApi {
    constructor(apiURL = Config.getInstance().FRONT_URL) {
        this.apiURL = `${apiURL}`
    }

    async get(endPoint: string, headers: any, refrechCallback?: Function) {
        const response = await fetch(this.apiURL + endPoint, {
            method: 'GET',
            headers,
        })
        
        if (refrechCallback) {
            return this.processResponse(response, ...)
        }
        
        const data = await this._getData(response)
        return { status: response.status, data }
    }

    async post(endPoint: string, body: any, headers: any, refrechCallback?: Function) {
        const isBodyFormData = this.isFormData(body)
        const response = await fetch(this.apiURL + endPoint, {
            method: 'POST',
            headers,
            body: isBodyFormData ? body : JSON.stringify(body),
        })
        
        const data = await this._getData(response)
        return { status: response.status, data }
    }
    
    // Similar methods for put, patch, delete
}
```

