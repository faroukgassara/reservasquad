# --- Database (PostgreSQL) ---
POSTGRES_USER=reservasquad
POSTGRES_PASSWORD=changeme
POSTGRES_DB=reservasquad
DATABASE_URL=postgresql://reservasquad:changeme@localhost:5432/reservasquad?schema=public

# --- Backend Auth ---
JWT_SECRET=change-me-secret
JWT_SECRET_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_SECRET_EXPIRES_IN=7d
JWT_RESET_SECRET=change-me-reset
JWT_RESET_SECRET_EXPIRES_IN=1h

# --- Backend ---
ENVIRONMENT=development
PORT=4000
HOST=0.0.0.0
FRONT_URL=http://localhost:3000

# --- SMTP (optional, password reset) ---
SMTP_HOST_ADDRESS=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
MAIL_ENCRYPTION=false
SMTP_SEND=false
MAIL_SECURE=false

# --- Seed (admin + default rooms) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme-strong
ADMIN_NAME=Administrator
